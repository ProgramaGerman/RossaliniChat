{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_TOKEN": "{file:~/.github_token}"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "token-optimizer": {
      "type": "local",
      "command": ["node", "node_modules/@ooples/token-optimizer-mcp/dist/server/index.js"],
      "enabled": true
    }
  },
  "permission": {
    "github_*": "allow",
    "filesystem_*": "allow",
    "context7_*": "allow"
  }
}
